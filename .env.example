# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_USER=etl_user
DB_PASSWORD=etl_password
DB_NAME=etl_db

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false
MINIO_BUCKET=etl-data

# ADEME Car Labelling (data.gouv.fr — Licence Ouverte v2.0)
# Dataset : "Données d'émissions de CO2 et de consommation de carburant des véhicules neufs"
# Laisser vide = recherche automatique par mots-clés sur data.gouv.fr
# Pour forcer un dataset précis : récupérer l'ID depuis l'URL data.gouv.fr/fr/datasets/{ID}/
ADEME_DATASET_ID=
# Optionnel : forcer un resource_id précis (laisser vide pour auto-détection)
ADEME_RESOURCE_ID=

# Scheduler Configuration
# Intervalle de rafraîchissement automatique en secondes (3600 = 1 heure)
REFRESH_INTERVAL=3600

# Application Configuration
PYTHONUNBUFFERED=1

# Groq Cloud API — Assistant IA "L'expert" (optionnel)
# Créer un compte gratuit sur https://console.groq.com et générer une clé API
# Modèle utilisé : Llama 3.3 70B (gratuit, ultra-rapide)
# Laisser vide pour désactiver l'assistant IA
GROQ_API_KEY=
